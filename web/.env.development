# Local development defaults for the Somra SPA.
# Vite dev server proxies /api/v1/* to http://localhost:8080 (see vite.config.ts),
# so this base URL stays relative to keep cookies / SSE on the same origin.
VITE_API_BASE_URL=/api/v1
# Override when the backend listens elsewhere (must match SOMRA_HTTP_ADDR).
# VITE_DEV_API_PROXY=http://127.0.0.1:8080
