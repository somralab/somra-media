# Somra — example environment configuration.
# Copy to .env (root or per-service) and adjust for your environment.
#
# This file is committed; do not put real secrets here.

# --- Backend (Go) ---
# Listen address for the HTTP API gateway.
SOMRA_HTTP_ADDR=:8080
# Legacy alias (still supported by some docs).
SOMRA_LISTEN_ADDR=:8080
# Filesystem location for SQLite + future data dirs.
SOMRA_DATA_DIR=./data
# Transcode segment cache directory (streaming module).
SOMRA_CACHE_DIR=./cache
# JWT signing secret (≥32 bytes recommended). Required in production.
SOMRA_JWT_SECRET=change-me-in-production-use-32-plus-chars
# Optional pepper for refresh-token hashing (defaults to JWT secret).
# SOMRA_REFRESH_PEPPER=
# Access/refresh token TTL overrides (Go duration, e.g. 15m, 168h).
# SOMRA_JWT_ACCESS_TTL=15m
# SOMRA_JWT_REFRESH_TTL=168h
# Set true when serving HTTPS so refresh cookies get Secure flag.
# SOMRA_AUTH_SECURE_COOKIE=false

# --- Frontend (web/) ---
# Base URL the SPA uses to reach the API. Default (relative) keeps cookies
# and SSE on the same origin. During `pnpm dev` Vite proxies /api/v1/* to
# the backend listening on http://localhost:8080 (see web/vite.config.ts).
# See web/.env.development and web/.env.production for the values Vite uses
# automatically; this entry is for reference only.
VITE_API_BASE_URL=/api/v1
