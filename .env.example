# Somra — example environment configuration.
# Copy to .env (repo root) and adjust for your environment.
#
# This file is committed; do not put real secrets here.
# `make dev` / `make dev-backend` auto-source .env when present.

# --- Backend (Go) — HTTP ---
# Listen address for the API gateway.
SOMRA_HTTP_ADDR=:8080
# Legacy alias (still supported when SOMRA_HTTP_ADDR is unset).
# SOMRA_LISTEN_ADDR=:8080
# SOMRA_HTTP_READ_HEADER_TIMEOUT=10s
# SOMRA_HTTP_READ_TIMEOUT=30s
# SOMRA_HTTP_WRITE_TIMEOUT=0
# SOMRA_HTTP_IDLE_TIMEOUT=120s

# --- Backend — logging ---
SOMRA_LOG_LEVEL=info
# json (production/CI) or text (readable local dev)
SOMRA_LOG_FORMAT=json
# SOMRA_SHUTDOWN_TIMEOUT=10s

# --- Backend — data & cache ---
# SQLite + durable state. Use ./data for local dev or ./deploy/data for Docker parity.
SOMRA_DATA_DIR=./data
# Transcode segment cache (streaming module). Created on first playback if missing.
SOMRA_CACHE_DIR=./cache

# --- Backend — streaming / transcode (Sprint 04) ---
# SOMRA_STREAMING_MAX_CONCURRENT=2
# SOMRA_STREAMING_MAX_QUEUE=8
# SOMRA_STREAMING_SESSION_TTL=4h
# SOMRA_STREAMING_IDLE_TIMEOUT=15m
# Override when ffmpeg/ffprobe are not on PATH (macOS Homebrew example):
# SOMRA_FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# SOMRA_FFPROBE_BIN=/opt/homebrew/bin/ffprobe

# --- Backend — auth (Sprint 03+) ---
# JWT signing secret (≥32 bytes recommended). Required for stable sessions across restarts.
SOMRA_JWT_SECRET=change-me-in-production-use-32-plus-chars
# Optional pepper for refresh-token hashing (defaults to JWT secret).
# SOMRA_REFRESH_PEPPER=
# SOMRA_JWT_ACCESS_TTL=15m
# SOMRA_JWT_REFRESH_TTL=168h
# Set true when serving HTTPS so refresh cookies get Secure flag.
# SOMRA_AUTH_SECURE_COOKIE=false

# --- Backend — CORS (dev SPA origin) ---
# Comma-separated origins. Default allows http://localhost:5173 (Vite dev server).
# SOMRA_CORS_ORIGINS=http://localhost:5173

# --- Backend — static SPA (optional) ---
# Serve built frontend from Go binary (production / e2e). Empty = API only.
# SOMRA_WEB_DIR=web/dist

# --- Backend — metadata (optional) ---
# SOMRA_TMDB_API_KEY=

# --- Frontend (web/) ---
# Base URL the SPA uses to reach the API. Relative keeps cookies on same origin.
# Vite dev proxies /api/v1/* → http://localhost:8080 (see web/vite.config.ts).
# Values for Vite modes live in web/.env.development and web/.env.production.
VITE_API_BASE_URL=/api/v1
# Override backend proxy target during `pnpm dev` (default http://localhost:8080).
# VITE_DEV_API_PROXY=http://127.0.0.1:8080
